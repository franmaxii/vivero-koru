---
import '../styles/global.css';
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Vivero Koru - Enverdece tu vida" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
		<title>{title} | Vivero Koru</title>
	</head>
	<body class="bg-koru-bg text-koru-text font-sans antialiased selection:bg-koru-light selection:text-white">
		<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-koru-dark/10">
			<div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
				<a href="/" class="font-serif text-3xl tracking-widest text-koru-text flex items-center gap-2">
					KORU
				</a>
				<ul class="flex gap-8 items-center text-sm tracking-wide font-medium">
					<li><a href="/" class="hover:text-koru-light transition-colors">Inicio</a></li>
					<li><a href="/productos" class="hover:text-koru-light transition-colors">Tienda</a></li>
					<li>
						<button id="cart-toggle" class="relative text-koru-dark hover:text-koru-light transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
							</svg>
							<span id="cart-badge" class="absolute -top-2 -right-2 bg-koru-light text-white text-xs rounded-full h-4 w-4 flex items-center justify-center hidden">0</span>
						</button>
					</li>
				</ul>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="bg-koru-dark text-white py-12 mt-20">
			<div class="max-w-6xl mx-auto px-4 text-center">
				<h2 class="font-serif text-2xl tracking-widest mb-4">KORU</h2>
				<p class="font-light italic tracking-widest mb-6">Enverdece tu vida</p>
				<p class="text-sm opacity-75">© {new Date().getFullYear()} Vivero Koru. Todos los derechos reservados.</p>
			</div>
		</footer>
	</body>
</html>