---
import Layout from '../layouts/Layout.astro';

const productos = [
    { 
        id: 1, 
        nombre: "Monstera Deliciosa", 
        categoria: "Interior", 
        precio: 25000, 
        descripcion: "Planta de interior muy popular por sus grandes hojas agujereadas. Ideal para darle un toque tropical y moderno a tu living.",
        img: "/img/monstera.jpg" 
    },
    { 
        id: 2, 
        nombre: "Ficus Lyrata", 
        categoria: "Árboles de interior", 
        precio: 35000, 
        descripcion: "Elegante y de hojas grandes en forma de violín. Perfecta para espacios amplios y bien iluminados.",
        img: "/img/ficus-lyrata.jpg" 
    },
    { 
        id: 3, 
        nombre: "Pothos Lemon", 
        categoria: "Colgantes", 
        precio: 12000, 
        descripcion: "Planta colgante de muy fácil cuidado con hojas de un vibrante tono verde limón. Se adapta bárbaro a departamentos.",
        img: "/img/pothos-lemon.jpg" 
    },
    { 
        id: 4, 
        nombre: "Sansevieria", 
        categoria: "Resistentes", 
        precio: 18000, 
        descripcion: "La clásica 'Lengua de Suegra'. Casi indestructible, purifica el aire y sobrevive perfecto a los climas secos.",
        img: "/img/sansevieria.jpg" 
    },
    { 
        id: 5, 
        nombre: "Calathea Triostar", 
        categoria: "Interior", 
        precio: 22000, 
        descripcion: "Destaca por el llamativo color rosado y blanco de sus hojas. Ideal para ambientes con buena humedad indirecta.",
        img: "/img/calathea.jpg" 
    },
    { 
        id: 6, 
        nombre: "Rosario (Senecio)", 
        categoria: "Suculentas", 
        precio: 15000, 
        descripcion: "Hermosa suculenta colgante que parece un delicado collar de perlas. Ideal para balcones o estantes altos.",
        img: "/img/rosario.jpg" 
    },
    { 
        id: 7, 
        nombre: "Lazo de Amor", 
        categoria: "Resistentes", 
        precio: 9500, 
        descripcion: "Un clásico súper noble. Crece rápido, da 'hijitos' y aporta un montón de frescura sin pedir mucho a cambio.",
        img: "/img/lazo-de-amor.jpg" 
    },
    { 
        id: 8, 
        nombre: "Peperomia Caperata", 
        categoria: "Pequeñas", 
        precio: 11000, 
        descripcion: "De tamaño compacto y hojas texturizadas. Perfecta para escritorios o mesas de luz que necesiten vida.",
        img: "/img/peperomia.jpg" 
    },
    { 
        id: 9, 
        nombre: "Aloe Vera", 
        categoria: "Cactus y Crasas", 
        precio: 8500, 
        descripcion: "Indispensable en cualquier hogar. Súper resistente al sol cordobés y conocida por sus propiedades curativas.",
        img: "/img/aloe.jpg" 
    }
];
---

<Layout title="Catálogo de Productos">
    <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="text-center mb-16">
            <span class="text-sm font-bold tracking-widest text-koru-light uppercase mb-2 block">Directo de nuestro invernadero</span>
            <h1 class="font-serif text-4xl md:text-5xl text-koru-dark mb-4">Plantas Aclimatadas</h1>
            <p class="text-gray-500 max-w-2xl mx-auto text-lg">
                Seleccionamos las especies que mejor se adaptan al clima de La Docta. 
                Armá tu carrito y llená de vida tus ambientes.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            {productos.map((producto) => (
                <div class="bg-white p-4 rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 group flex flex-col">
                    <div class="aspect-square overflow-hidden rounded-lg mb-4 bg-gray-50 relative">
                        <img src={producto.img} alt={producto.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                    </div>
                    <div class="flex justify-between items-start mb-2">
                        <div>
                            <p class="text-xs text-koru-light font-bold uppercase tracking-wider mb-1">{producto.categoria}</p>
                            <h3 class="font-serif text-lg text-koru-text">{producto.nombre}</h3>
                        </div>
                        <span class="font-semibold text-koru-dark whitespace-nowrap ml-2">${producto.precio.toLocaleString()}</span>
                    </div>
                    <p class="text-sm text-gray-500 mb-6 flex-grow leading-relaxed">{producto.descripcion}</p>
                    <button 
                        class="add-to-cart-btn w-full py-3 rounded-lg border-2 border-koru-dark text-koru-dark font-medium hover:bg-koru-dark hover:text-white transition-all active:scale-95 mt-auto"
                        data-id={producto.id}
                        data-nombre={producto.nombre}
                        data-precio={producto.precio}
                    >
                        Añadir al carrito
                    </button>
                </div>
            ))}
        </div>

        <div class="bg-gradient-to-br from-koru-bg to-white rounded-2xl p-8 md:p-12 text-center border border-koru-light/20 shadow-sm">
            <div class="h-12 w-12 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm text-2xl">🛵</div>
            <h3 class="font-serif text-2xl text-koru-dark mb-3">Envíos en Córdoba Capital</h3>
            <p class="text-gray-600 mb-6 max-w-xl mx-auto">
                Hacemos entregas a domicilio coordinadas en <strong>Nueva Córdoba, General Paz, Centro y Alberdi</strong>. 
                Si estás en otro barrio consultanos. También podés retirar tu pedido sin cargo por nuestro punto de entrega.
            </p>
            <div class="flex flex-wrap justify-center gap-6 text-sm font-medium text-koru-text">
                <span class="flex items-center gap-2">🌱 Plantas sanas y cuidadas</span>
                <span class="hidden sm:inline text-gray-300">|</span>
                <span class="flex items-center gap-2">💳 Aceptamos transferencias</span>
            </div>
        </div>
    </div>

    <div id="cart-sidebar" class="fixed inset-y-0 right-0 w-full md:w-[400px] bg-white shadow-2xl transform translate-x-full transition-transform duration-300 z-50 flex flex-col border-l border-gray-200">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-koru-bg">
            <div class="flex items-center gap-2">
                <span class="text-2xl">🛒</span>
                <h2 class="font-serif text-2xl text-koru-dark">Tu Carrito</h2>
            </div>
            <button id="close-cart" class="text-gray-400 hover:text-koru-dark p-2 rounded-full hover:bg-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        
        <div id="cart-items" class="flex-1 overflow-y-auto p-6 flex flex-col gap-4">
            <div class="flex flex-col items-center justify-center h-full text-gray-400 space-y-4">
                <span class="text-4xl opacity-50">🪴</span>
                <p class="italic">Tu carrito está esperando por vida</p>
            </div>
        </div>

        <div class="p-6 border-t border-gray-100 bg-gray-50">
            <div class="flex justify-between items-end mb-6">
                <span class="text-gray-500 font-medium">Total estimado:</span>
                <span id="cart-total" class="text-2xl font-bold text-koru-dark">$0</span>
            </div>
            <button id="checkout-btn" class="w-full bg-[#25D366] hover:bg-[#128C7E] text-white py-4 rounded-xl font-semibold flex items-center justify-center gap-3 transition-colors shadow-md hover:shadow-lg active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Pedir por WhatsApp
            </button>
            <p class="text-xs text-center text-gray-400 mt-4">Al enviar el pedido, coordinamos el envío y el pago.</p>
        </div>
    </div>

    <div id="cart-overlay" class="fixed inset-0 bg-black/40 hidden z-40 backdrop-blur-sm transition-opacity"></div>

    <script>
        let carrito = [];
        const NRO_WHATSAPP = "5493813580986"; 

        const toggleBtn = document.getElementById('cart-toggle');
        const closeBtn = document.getElementById('close-cart');
        const sidebar = document.getElementById('cart-sidebar');
        const overlay = document.getElementById('cart-overlay');
        const itemsContainer = document.getElementById('cart-items');
        const totalEl = document.getElementById('cart-total');
        const badge = document.getElementById('cart-badge');
        const checkoutBtn = document.getElementById('checkout-btn');

        function toggleCart() {
            sidebar.classList.toggle('translate-x-full');
            overlay.classList.toggle('hidden');
        }
        
        if(toggleBtn) toggleBtn.addEventListener('click', toggleCart);
        closeBtn.addEventListener('click', toggleCart);
        overlay.addEventListener('click', toggleCart);

        function updateCart() {
            itemsContainer.innerHTML = '';
            let total = 0;
            let qty = 0;

            if (carrito.length === 0) {
                itemsContainer.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-full text-gray-400 space-y-4">
                        <span class="text-4xl opacity-50">🪴</span>
                        <p class="italic">Tu carrito está esperando por vida</p>
                    </div>
                `;
                if(badge) badge.classList.add('hidden');
            } else {
                carrito.forEach((item, index) => {
                    total += item.precio * item.cantidad;
                    qty += item.cantidad;
                    
                    itemsContainer.innerHTML += `
                        <div class="flex justify-between items-center bg-white p-4 rounded-xl border border-gray-100 shadow-sm">
                            <div>
                                <p class="font-serif text-koru-text font-medium">${item.nombre}</p>
                                <p class="text-sm text-koru-dark mt-1">${item.cantidad} x $${item.precio.toLocaleString()}</p>
                            </div>
                            <button onclick="window.removeItem(${index})" class="text-red-400 hover:text-red-600 text-sm font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Quitar</button>
                        </div>
                    `;
                });
                if(badge) badge.classList.remove('hidden');
            }
            
            if(badge) badge.innerText = qty;
            totalEl.innerText = `$${total.toLocaleString()}`;
        }

        window.removeItem = (index) => {
            carrito.splice(index, 1);
            updateCart();
        };

        document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = e.target.dataset.id;
                const nombre = e.target.dataset.nombre;
                const precio = parseInt(e.target.dataset.precio);

                const existente = carrito.find(item => item.id === id);
                if (existente) {
                    existente.cantidad += 1;
                } else {
                    carrito.push({ id, nombre, precio, cantidad: 1 });
                }
                
                updateCart();
                toggleCart(); 
            });
        });

        checkoutBtn.addEventListener('click', () => {
            if (carrito.length === 0) return alert('¡Tu carrito está vacío! Agregá algunas plantas primero.');
            
            let mensaje = "¡Hola Vivero Koru! 🌱 Me gustaría encargar las siguientes plantas en Córdoba:\n\n";
            let total = 0;
            
            carrito.forEach(item => {
                const subtotal = item.precio * item.cantidad;
                total += subtotal;
                mensaje += `🪴 ${item.cantidad}x ${item.nombre} ($${subtotal.toLocaleString()})\n`;
            });
            
            mensaje += `\n*Total estimado: $${total.toLocaleString()}*\n\nMe gustaría coordinar el envío/retiro y el pago. ¡Gracias!`;
            
            const url = `https://wa.me/${NRO_WHATSAPP}?text=${encodeURIComponent(mensaje)}`;
            window.open(url, '_blank');
        });
    </script>
</Layout>