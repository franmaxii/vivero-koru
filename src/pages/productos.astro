---
import Layout from '../layouts/Layout.astro';

const productos = [
	{ id: 1, nombre: "Helecho Nido de Ave", categoria: "Helechos", precio: 12000, img: "https://images.unsplash.com/photo-1599598425947-33002629d479?q=80&w=500&auto=format&fit=crop" },
	{ id: 2, nombre: "Echeveria Elegans", categoria: "Suculentas", precio: 4500, img: "https://images.unsplash.com/photo-1509423350716-97f9360b4e09?q=80&w=500&auto=format&fit=crop" },
	{ id: 3, nombre: "Cactus San Pedro Mini", categoria: "Cactus", precio: 8500, img: "https://images.unsplash.com/photo-1459156212016-c812468e2115?q=80&w=500&auto=format&fit=crop" },
	{ id: 4, nombre: "Helecho Boston", categoria: "Helechos", precio: 15000, img: "https://images.unsplash.com/photo-1506377247377-2a5b3b417ebb?q=80&w=500&auto=format&fit=crop" },
	{ id: 5, nombre: "Haworthia Fasciata", categoria: "Suculentas", precio: 5000, img: "https://images.unsplash.com/photo-1616474640108-72b9a71a9da5?q=80&w=500&auto=format&fit=crop" },
	{ id: 6, nombre: "Opuntia Microdasys", categoria: "Cactus", precio: 6000, img: "https://images.unsplash.com/photo-1551893665-f843f600794e?q=80&w=500&auto=format&fit=crop" }
];
---

<Layout title="Catálogo de Productos">
	<div class="max-w-6xl mx-auto px-4 py-12">
		<div class="text-center mb-12">
			<h1 class="font-serif text-4xl text-koru-dark mb-4">Nuestra Colección</h1>
			<p class="text-gray-500">Selecciona las plantas que darán vida a tu hogar.</p>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{productos.map((producto) => (
				<div class="bg-white p-4 rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 group">
					<div class="aspect-square overflow-hidden rounded-lg mb-4 bg-gray-50">
						<img src={producto.img} alt={producto.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
					<div class="flex justify-between items-start mb-4">
						<div>
							<p class="text-xs text-koru-light font-bold uppercase tracking-wider mb-1">{producto.categoria}</p>
							<h3 class="font-serif text-lg text-koru-text">{producto.nombre}</h3>
						</div>
						<span class="font-semibold text-koru-dark">${producto.precio.toLocaleString()}</span>
					</div>
					<button 
						class="add-to-cart-btn w-full py-3 rounded-lg border border-koru-dark text-koru-dark font-medium hover:bg-koru-dark hover:text-white transition-colors"
						data-id={producto.id}
						data-nombre={producto.nombre}
						data-precio={producto.precio}
					>
						Añadir al carrito
					</button>
				</div>
			))}
		</div>
	</div>

	<div id="cart-sidebar" class="fixed inset-y-0 right-0 w-full md:w-96 bg-white shadow-2xl transform translate-x-full transition-transform duration-300 z-50 flex flex-col border-l border-gray-200">
		<div class="p-6 border-b border-gray-100 flex justify-between items-center bg-koru-bg">
			<h2 class="font-serif text-2xl text-koru-dark">Tu Carrito</h2>
			<button id="close-cart" class="text-gray-400 hover:text-koru-dark">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
			</button>
		</div>
		
		<div id="cart-items" class="flex-1 overflow-y-auto p-6 flex flex-col gap-4">
			<p class="text-gray-400 text-center italic mt-10">Tu carrito está vacío</p>
		</div>

		<div class="p-6 border-t border-gray-100 bg-gray-50">
			<div class="flex justify-between text-lg font-semibold text-koru-text mb-4">
				<span>Total:</span>
				<span id="cart-total">$0</span>
			</div>
			<button id="checkout-btn" class="w-full bg-[#25D366] hover:bg-[#128C7E] text-white py-4 rounded-lg font-semibold flex items-center justify-center gap-2 transition-colors shadow-lg">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
				Comprar por WhatsApp
			</button>
		</div>
	</div>

	<div id="cart-overlay" class="fixed inset-0 bg-black/50 hidden z-40 backdrop-blur-sm transition-opacity"></div>

	<script>
		let carrito = [];
		const NRO_WHATSAPP = "5493813580986"; // Reemplaza con el número de Koru

		// Elementos del DOM
		const toggleBtn = document.getElementById('cart-toggle');
		const closeBtn = document.getElementById('close-cart');
		const sidebar = document.getElementById('cart-sidebar');
		const overlay = document.getElementById('cart-overlay');
		const itemsContainer = document.getElementById('cart-items');
		const totalEl = document.getElementById('cart-total');
		const badge = document.getElementById('cart-badge');
		const checkoutBtn = document.getElementById('checkout-btn');

		// UI del Carrito
		function toggleCart() {
			sidebar.classList.toggle('translate-x-full');
			overlay.classList.toggle('hidden');
		}
		
		toggleBtn.addEventListener('click', toggleCart);
		closeBtn.addEventListener('click', toggleCart);
		overlay.addEventListener('click', toggleCart);

		// Funcionalidad
		function updateCart() {
			itemsContainer.innerHTML = '';
			let total = 0;
			let qty = 0;

			if (carrito.length === 0) {
				itemsContainer.innerHTML = '<p class="text-gray-400 text-center italic mt-10">Tu carrito está vacío</p>';
				badge.classList.add('hidden');
			} else {
				carrito.forEach((item, index) => {
					total += item.precio * item.cantidad;
					qty += item.cantidad;
					
					itemsContainer.innerHTML += `
						<div class="flex justify-between items-center bg-white p-3 rounded border border-gray-100">
							<div>
								<p class="font-serif text-sm">${item.nombre}</p>
								<p class="text-xs text-koru-dark">${item.cantidad} x $${item.precio.toLocaleString()}</p>
							</div>
							<button onclick="window.removeItem(${index})" class="text-red-400 hover:text-red-600 text-xs font-semibold">Quitar</button>
						</div>
					`;
				});
				badge.classList.remove('hidden');
			}
			
			badge.innerText = qty;
			totalEl.innerText = `$${total.toLocaleString()}`;
		}

		window.removeItem = (index) => {
			carrito.splice(index, 1);
			updateCart();
		};

		// Agregar eventos a botones
		document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const id = e.target.dataset.id;
				const nombre = e.target.dataset.nombre;
				const precio = parseInt(e.target.dataset.precio);

				const existente = carrito.find(item => item.id === id);
				if (existente) {
					existente.cantidad += 1;
				} else {
					carrito.push({ id, nombre, precio, cantidad: 1 });
				}
				
				updateCart();
				toggleCart(); // Abre el carrito al añadir
			});
		});

		// Enviar a WhatsApp
		checkoutBtn.addEventListener('click', () => {
			if (carrito.length === 0) return alert('Tu carrito está vacío');
			
			let mensaje = "Hola Vivero Koru 🌱, me gustaría encargar los siguientes productos:\n\n";
			let total = 0;
			
			carrito.forEach(item => {
				const subtotal = item.precio * item.cantidad;
				total += subtotal;
				mensaje += `- ${item.cantidad}x ${item.nombre} ($${subtotal.toLocaleString()})\n`;
			});
			
			mensaje += `\n*Total a pagar: $${total.toLocaleString()}*\n\n¡Muchas gracias!`;
			
			const url = `https://wa.me/${NRO_WHATSAPP}?text=${encodeURIComponent(mensaje)}`;
			window.open(url, '_blank');
		});
	</script>
</Layout>